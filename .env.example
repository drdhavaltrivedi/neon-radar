# 🧬 Neon Radar Environment Configuration

# GEMINI_API_KEY: Required for AI-powered transmission encryption (future)
GEMINI_API_KEY="your_api_key_here"

# PORT: The port your server will listen on. (Default: 3000)
# Railway will automatically set this value in production.
PORT=3000

# NODE_ENV: Set to 'production' for Railway, 'development' for local work.
NODE_ENV="development"

# PERSISTENCE: Data directory for transmission logs (Rooms & Messages)
# Defaults to './data' if not set.
DATA_DIR="./data"

# (Future Requirement) NEON_DATABASE_URL: For persistent SQL storage
# NEON_DATABASE_URL="postgres://user:password@neon.tech/neonradar"
